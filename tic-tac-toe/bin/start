#!/usr/bin/env ruby

require 'telegram/bot'
require_relative 'lib/tic/tac/toe'

token = 'YOUR_TELEGRAM_BOT_API_TOKEN' #Андрей даст токен, я верю в это!!!!!!!

puts "Бот запущен... Нажми Ctrl+C для остановки."

Telegram::Bot::Client.run(token) do |bot|
  bot.listen do |message|
    user = Tic::Tac::Toe::Bot.handle_user(message)
    
    case message.text
    when '/start'
      bot.api.send_message(chat_id: message.chat.id, text: "Привет, #{user[:name]}! Я готов к игре.")
    when '/stop'
      bot.api.send_message(chat_id: message.chat.id, text: "Пока-пока!")
    end
  end
end